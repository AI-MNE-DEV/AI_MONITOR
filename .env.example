# === AI MONITOR - Variabili d'Ambiente ===

# Porta esposta dall'host (default: 8000)
AI_MONITOR_PORT=8000

# Percorso del database SQLite (default: data/ai_monitor.db)
AI_MONITOR_DB_PATH=data/ai_monitor.db

# Docker socket (usato internamente dall'SDK Docker via DOCKER_HOST)
# DOCKER_HOST=unix:///var/run/docker.sock

# Soglie Alert Manager
ALERT_CPU_WARNING=90.0
ALERT_CPU_CRITICAL=95.0
ALERT_RAM_WARNING=85.0
ALERT_RAM_CRITICAL=90.0
ALERT_COOLDOWN_SECONDS=60

# Path file di fallback per allarmi critici
CRITICAL_ALERTS_PATH=CRITICAL_ALERTS.txt

# Intervallo di polling telemetria in secondi
AI_MONITOR_POLL_INTERVAL=5.0

# --- Notifiche Esterne ---

# Telegram Bot (ottenere token da @BotFather, chat_id da @userinfobot)
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=

# Webhook generico (POST JSON a qualsiasi endpoint)
NOTIFY_WEBHOOK_ENABLED=false
NOTIFY_WEBHOOK_URL=

# Email SMTP (es. Gmail: smtp.gmail.com:587 con App Password)
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_SMTP_HOST=
NOTIFY_EMAIL_SMTP_PORT=587
NOTIFY_EMAIL_SMTP_USER=
NOTIFY_EMAIL_SMTP_PASS=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_USE_TLS=true

# Livello minimo per inviare notifiche: CRITICAL o WARNING
NOTIFY_MIN_LEVEL=CRITICAL

# Timeout HTTP per notifiche in secondi
NOTIFY_HTTP_TIMEOUT=10.0
